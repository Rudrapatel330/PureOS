megs: 1024 
romimage: file=D:\bochs\Bochs-3.0\BIOS-bochs-latest 
vgaromimage: file=D:\bochs\Bochs-3.0\VGABIOS-lgpl-latest 
boot: floppy 
floppya: 1_44=build/pureos.img, status=inserted 
ata1: enabled=1, ioaddr1=0x170, ioaddr2=0x370, irq=15
ata1-master: type=disk, path="data.img", mode=flat, cylinders=20, heads=16, spt=63
log: bochslog.txt 
cpu: reset_on_triple_fault=1 
panic: action=report 
display_library: win32 
com1: enabled=1, mode=file, dev=serial.log

